# Where the production checker lives (proof.py shells to scripts/prove-one.ts).
BRAINBLAST_CORE_DIR=../../packages/core
# Registry ingest for validated VTIs (validator forwards accepted data here).
BRAINBLAST_REGISTRY_URL=https://registry.brainblast.tech
# Miner: directory of candidate JSONs to serve (the fleet's candidates dir works).
BRAINBLAST_CANDIDATE_QUEUE=./queue
# Standard bittensor wallet env (see docs.learnbittensor.org):
# BT_WALLET_NAME=brainblast
# BT_WALLET_HOTKEY=default
# BT_SUBTENSOR_NETWORK=finney   # or 'local' for localnet dev
