{
  "name": "@brainblast/core",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Shared engine extracted from the T1/T2 spikes: detect -> check (vetted templates) -> emit report.json -> generate behavioral contract tests. Rules are pure data.",
  "bin": { "brainblast": "src/cli.ts" },
  "scripts": {
    "audit": "tsx src/cli.ts",
    "prove": "tsx scripts/prove.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ts-morph": "^23",
    "yaml": "^2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2",
    "jose": "^5",
    "stripe": "^17",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
