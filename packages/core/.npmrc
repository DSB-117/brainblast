# tree-sitter-rust@0.24.0 declares a stale peerOptional on tree-sitter@^0.22, but
# runs fine against the 0.25 binding that tree-sitter-go/solidity require (verified
# by the full Rust/Anchor test suite). No single tree-sitter version satisfies all
# three peer decls, so accept the peerOptional mismatch. Remove once a
# tree-sitter-rust peering on ^0.25 ships.
legacy-peer-deps=true
